# Copie para .env e ajuste.

# --- LLM -------------------------------------------------------------------
# Padrão: Ollama Cloud (mesma conta do roger). Usado SÓ pra compor a descrição;
# nunca pra extrair dado do invoice. Deixe OLLAMA_API_KEY vazio pra usar Ollama
# LOCAL (e aponte OLLAMA_BASE_URL pra http://localhost:11434).
OLLAMA_API_KEY=
OLLAMA_BASE_URL=https://ollama.com
OLLAMA_MODEL=qwen3.5:397b-cloud

# --- Servidor --------------------------------------------------------------
HOST=0.0.0.0
PORT=8000

# --- Pastas ----------------------------------------------------------------
TEMPLATES_DIR=./data/templates
CACHE_DIR=./data/cache
SAIDA_DIR=./data/saida
